# ═══════════════════════════════════════════════════════════
# PERMIC MEN'S WEAR — BACKEND ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# This file is SAFE to commit. It contains no real secrets.
# On Render: copy these keys into the Environment tab.
# Locally: copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=10000

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://YOUR-APP.vercel.app

# Database — Supabase PostgreSQL connection string
# Get from: supabase.com → Settings → Database → URI
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=8h

# M-Pesa — from developer.safaricom.co.ke → My Apps → Production
MPESA_ENV=production
MPESA_SHORTCODE=YOUR_PAYBILL_NUMBER
MPESA_ACCOUNT=YOUR_ACCOUNT_NUMBER
MPESA_CONSUMER_KEY=YOUR_PRODUCTION_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_PRODUCTION_CONSUMER_SECRET
MPESA_PASSKEY=YOUR_PRODUCTION_PASSKEY
MPESA_CALLBACK_URL=https://YOUR-APP.onrender.com/api/mpesa/callback
MPESA_C2B_VALIDATION_URL=https://YOUR-APP.onrender.com/api/mpesa/c2b-validate
MPESA_C2B_CONFIRMATION_URL=https://YOUR-APP.onrender.com/api/mpesa/c2b-callback

# Africa's Talking SMS — from account.africastalking.com
AT_API_KEY=YOUR_AT_API_KEY
AT_USERNAME=YOUR_AT_USERNAME
AT_SENDER_ID=PERMICWEAR
ADMIN_PHONE=+254700000000

# Gmail Email Alerts
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=your@gmail.com
